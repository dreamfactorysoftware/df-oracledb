  "require-dev": {
    "laravel/framework": "^11.15 || ^12.0 || ^13.7",
    "mockery/mockery": "^1.6",
    "nunomaduro/collision": "^7.0 || ^8.6",
    "phpunit/phpunit": "^10.5 || ^11.5.3",
    "orchestra/testbench": "^9.0 || ^10.0 || ^11.0"
  },
  "autoload": {
    "psr-4": {
      "DreamFactory\\Core\\Oracle\\": "src/"
    }
  },
  "extra": {
    "branch-alias": {
      "dev-develop": "0.15.x-dev"
    },
    "laravel": {
